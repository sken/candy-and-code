---
---
<div class="dialogue-mirror relative my-16 flex flex-col gap-y-12">
  <!-- The Mirror Line (Desktop only) -->
  <div
    class="absolute top-0 left-1/2 z-0 hidden h-full w-px -translate-x-1/2 bg-accent/20 md:block"
  >
  </div>
  <slot />
</div>

<script>
  function setupReveal() {
    const observerOptions = {
      root: null,
      rootMargin: "0px",
      threshold: 0.15,
    };

    const revealItems = document.querySelectorAll(".reveal-item");

    // Entrance Reveal
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove("opacity-0", "translate-y-8", "blur-md");
          entry.target.classList.add("opacity-100", "translate-y-0", "blur-none");
          revealObserver.unobserve(entry.target);
        }
      });
    }, observerOptions);

    revealItems.forEach((item) => revealObserver.observe(item));

    // Focus on Scroll
    const handleScroll = () => {
      const centerY = window.innerHeight / 2;
      let closestItem: Element | null = null;
      let minDistance = Infinity;

      revealItems.forEach((item) => {
        const rect = item.getBoundingClientRect();
        const itemCenterY = rect.top + rect.height / 2;
        const distance = Math.abs(centerY - itemCenterY);

        if (distance < minDistance) {
          minDistance = distance;
          closestItem = item;
        }
      });

      revealItems.forEach((item) => {
        if (item === closestItem) {
          item.classList.add("is-focused");
        } else {
          item.classList.remove("is-focused");
        }
      });
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll(); // Initial check

    // Cleanup on page swap
    document.addEventListener("astro:before-swap", () => {
      window.removeEventListener("scroll", handleScroll);
    }, { once: true });
  }

  // Initial setup
  setupReveal();

  // Re-run after view transitions
  document.addEventListener("astro:after-swap", setupReveal);
</script>
